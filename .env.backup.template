# .env.backup — CarsAuto Backup & Disaster Recovery Configuration
# Copy to project root as .env.backup and fill in values.
# NEVER commit this file — it contains secrets.
# Add to .gitignore: .env.backup

# ── Local Backup Storage ──────────────────────────────────────────────────────
# Path where backups are stored locally (absolute or relative to project root)
BACKUP_DIR=./backups

# Days to retain local backups before auto-cleanup
RETENTION_DAYS=30

# Hours before a missing/stale backup triggers a warning
WARN_AGE_HOURS=26

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONTAINER=cars_auto_db
POSTGRES_USER=carsauto
POSTGRES_DB=carsauto
# POSTGRES_PASSWORD is read from your main .env — no need to duplicate here

# ── Encryption (strongly recommended) ────────────────────────────────────────
# Backups are encrypted with AES-256 using this passphrase.
# Store this passphrase in your password manager — without it, encrypted
# backups cannot be restored.
# Generate: openssl rand -base64 32
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── Cloudinary Image Backup ───────────────────────────────────────────────────
# These should match your main .env values
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# ── Offsite Storage (AWS S3 / S3-compatible) ──────────────────────────────────
# Leave blank to skip S3 upload
S3_BUCKET=
# S3_BUCKET=your-backup-bucket-name

# S3 key prefix (folder inside the bucket)
S3_PREFIX=carsauto-backups

# AWS credentials (if not using instance profiles or env vars)
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_DEFAULT_REGION=me-south-1   # Bahrain region — closest to Iraq/Gulf

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack incoming webhook URL for backup success/failure alerts
# Leave blank to disable
SLACK_WEBHOOK_URL=

# ── Minimum Size Guards ───────────────────────────────────────────────────────
# Backups smaller than these are flagged as potentially corrupt
MIN_DB_SIZE_BYTES=10240    # 10KB
MIN_IMG_SIZE_BYTES=1024    # 1KB
