# ══════════════════════════════════════════════════════════════════════════════
# .gitignore  —  CarsAuto monorepo
# ══════════════════════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
out/
apps/api/dist/
apps/web/.next/

# ── Turbo ─────────────────────────────────────────────────────────────────────
.turbo/
.turbo/cache/

# ── Environment files  ─  NEVER commit any .env with real secrets ─────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.development

# Per-app env files (committed as .env.example instead)
apps/api/.env
apps/web/.env.local

# Keep example / template files
!.env.example
!apps/api/.env.example
!apps/web/.env.local.example
!.env.production.template

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Test / coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Database backups ──────────────────────────────────────────────────────────
backups/
*.sql
*.sql.gz

# ── Merged from .gitignore.txt ───────────────────────────────────────────────
.next/
.env.development.local
.env.test.local
.env.production.local
apps/api/prisma/migrations/
