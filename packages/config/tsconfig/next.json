{
  "extends": "./base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "downlevelIteration": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@ui/*": ["../../packages/ui/src/*"],
      "@types/*": ["../../packages/types/src/*"],
      "@utils/*": ["../../packages/utils/src/*"]
    }
  }
}