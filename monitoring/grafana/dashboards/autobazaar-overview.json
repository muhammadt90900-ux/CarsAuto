{
  "title": "AutoBazaar Pro — API Overview",
  "uid":   "autobazaar-api",
  "tags":  ["autobazaar", "api"],
  "time":  { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_total[1m]))", "legendFormat": "req/s" }]
    },
    {
      "id": 2, "type": "stat", "title": "Error Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_total{status_code=~'5..'}[5m])) / sum(rate(http_requests_total[5m]))", "legendFormat": "5xx rate" }],
      "options": { "unit": "percentunit" }
    },
    {
      "id": 3, "type": "stat", "title": "p95 Latency",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" }],
      "options": { "unit": "s" }
    },
    {
      "id": 4, "type": "stat", "title": "Active Heap (MB)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "autobazaar_node_process_heap_bytes{type='used'} / 1024 / 1024" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Request Rate by Status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by(status_code)(rate(http_requests_total[1m]))", "legendFormat": "{{status_code}}" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Request Duration Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "DB Slow Queries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [{ "expr": "rate(autobazaar_db_slow_queries_total[5m])", "legendFormat": "slow queries/s" }]
    },
    {
      "id": 8, "type": "timeseries", "title": "Auth Events",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [
        { "expr": "sum by(action,result)(rate(autobazaar_auth_attempts_total[5m]))", "legendFormat": "{{action}} {{result}}" }
      ]
    }
  ],
  "schemaVersion": 38
}
