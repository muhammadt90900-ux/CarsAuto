{
  "name": "cars-auto",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=api",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js}\" \"packages/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js}\" \"packages/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit --project apps/api/tsconfig.json && tsc --noEmit --project apps/web/tsconfig.json",
    "test": "turbo run test",
    "test:api": "npm run test --workspace=apps/api",
    "test:web": "npm run test --workspace=apps/web",
    "test:ci": "turbo run test:ci",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "validate:deploy": "./scripts/validate-deploy.sh",
    "audit:check": "npm audit --audit-level=high",
    "clean": "turbo run clean && rm -rf node_modules",
    "docker:dev": "docker compose up --build",
    "docker:prod": "docker compose -f docker-compose.yml up --build -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "prettier": "^3.0.0",
    "turbo": "latest"
  },
  "dependencies": {
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/testing": "^11.1.26",
    "@nestjs/websockets": "^11.1.26",
    "deepseek": "^0.0.2",
    "multer": "2.1.1",
    "next": "16.2.7",
    "next-intl": "4.13.0",
    "nodemailer": "8.0.10",
    "sharp": "^0.35.2"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "ws": ">=8.17.1"
  }
}
