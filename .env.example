# ──────────────────────────────────────────────────────────────────────────────
# .env.example  —  Monorepo root / docker-compose secrets
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in every CHANGE_ME value before running docker-compose.
#
# This file is used by docker-compose.yml for all services.
# NEVER commit .env  (it is listed in .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=carsauto
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=carsauto
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_PORT=6379

# ── API (NestJS) ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
LOG_LEVEL=log
SLOW_QUERY_THRESHOLD_MS=500

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_char_random_hex_secret
JWT_EXPIRES_IN=15m

# NOTE: Refresh tokens are opaque random hex strings stored as SHA-256 hashes
# in the database (RefreshToken table). They are NOT JWTs, so no
# JWT_REFRESH_SECRET is needed. The refresh endpoint validates against the DB.
# JWT_REFRESH_SECRET is intentionally absent — do not add it.

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com,https://www.yourdomain.com

# ── Cookie SameSite ───────────────────────────────────────────────────────────
# ✅ FIX #3: Controls the SameSite attribute of the refresh_token cookie.
#
# Use 'lax'  → same-site production deployment (frontend + API on same domain)
# Use 'none' → cross-origin (Codespaces, separate subdomains, different ports)
#
# IMPORTANT: 'none' requires HTTPS (secure=true). In Codespaces, GitHub
# forwards HTTPS automatically so this works out of the box.
#
# For local dev (http://localhost):
#   - Same port: COOKIE_SAME_SITE=lax   (e.g. API proxied through Next.js)
#   - Different ports: COOKIE_SAME_SITE=none + run API behind https-localhost
COOKIE_SAME_SITE=lax

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# Set to 'true' to skip real upload endpoint during local dev (returns data-URL)
NEXT_PUBLIC_USE_MOCK_UPLOAD=false

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME_smtp_password
MAIL_FROM=noreply@yourdomain.com

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=CHANGE_ME

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=CHANGE_ME_sk_live_or_sk_test_key

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_EMAIL=noreply@yourdomain.com

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password
GRAFANA_URL=https://monitoring.yourdomain.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=log                    # verbose | debug | log | warn | error
LOG_SAMPLE_RATE=1.0              # 0.0–1.0 — sample rate for info-level request logs
APP_VERSION=1.0.0
SENTRY_DSN=                      # Optional: Sentry DSN for error tracking
