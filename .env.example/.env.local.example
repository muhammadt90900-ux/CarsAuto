# ──────────────────────────────────────────────
# apps/web/.env.local  —  Next.js frontend
# Copy this file to apps/web/.env.local and fill in real values.
# Variables prefixed NEXT_PUBLIC_* are exposed to the browser.
# ──────────────────────────────────────────────

# ── API base URL ──────────────────────────────
# Local dev:        http://localhost:4000/api
# Docker (web→api): http://api:4000/api        (server-side fetch inside Docker)
# Vercel / Render:  https://your-api.railway.app/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ── Internal API URL (SSR / server components only) ───────────────────────────
# When the Next.js container talks to the API container on the same Docker network
# use the internal hostname so traffic never leaves the private network.
# On Vercel this can stay the same as NEXT_PUBLIC_API_URL.
INTERNAL_API_URL=http://localhost:4000/api

# ── Next.js ───────────────────────────────────
NEXT_TELEMETRY_DISABLED=1

# ── Auth (if using NextAuth / Auth.js) ────────
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=change-this-to-a-strong-random-secret

# ── Cloudinary (if uploading from the browser) ─
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
