model TransactionLog {
  // PARTITIONED IN PRODUCTION (Phase 2 / Prompt 2.3, once
  // migrations-manual/partition-transaction-logs.sql has been run) —
  // monthly RANGE partitions on "createdAt". Do NOT run `prisma db push`
  // destructively against this table; use the manual migration process in
  // apps/api/prisma/migrations-manual/PARTITIONING-RUNBOOK.md.
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  paymentId    String   @db.Uuid
  payment      Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  event        String   @db.VarChar(100)
  status       String   @db.VarChar(50)
  amount       Decimal? @db.Decimal(12, 2)
  currency     String?  @db.Char(3)
  // F1.4: mirrors Payment.exchangeRateToUsd/amountUsd — a TransactionLog row
  // can represent a partial refund or a different point in time than the
  // parent Payment's current state, so it needs its own snapshot rather
  // than joining back to Payment for this.
  exchangeRateToUsd Decimal? @db.Decimal(18, 8)
  amountUsd         Decimal? @db.Decimal(20, 8)
  gatewayId    String?  @db.VarChar(255)
  gatewayData  Json?
  errorMessage String?  @db.Text

  createdAt    DateTime @default(now())

  @@index([paymentId])
  @@index([event])
  @@index([createdAt(sort: Desc)])
  @@map("transaction_logs")
}

