// DEALER
// CHANGE: averageRating → Decimal(3,2); totalViews → BigInt;
//         composite index for marketplace browse (status+tier+rating)
// ─────────────────────────────────────────────────────────────────────────────

model Dealer {
  id     String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug          String  @unique @db.VarChar(100)
  nameEn        String  @db.VarChar(150)
  nameAr        String  @db.VarChar(150)
  nameKu        String  @db.VarChar(150)
  taglineEn     String? @db.VarChar(255)
  taglineAr     String? @db.VarChar(255)
  taglineKu     String? @db.VarChar(255)
  descriptionEn String? @db.Text
  descriptionAr String? @db.Text
  descriptionKu String? @db.Text

  logoUrl     String?
  coverUrl    String?
  brandColors Json?

  status     DealerStatus @default(PENDING)
  tier       DealerTier   @default(BASIC)
  verifiedAt DateTime?
  verifiedBy String?      @db.Uuid

  phone     String? @db.VarChar(30)
  whatsapp  String? @db.VarChar(30)
  email     String? @db.VarChar(254)
  website   String?
  instagram String? @db.VarChar(100)
  facebook  String? @db.VarChar(100)
  telegram  String? @db.VarChar(100)

  locationId String?   @db.Uuid
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  address    String?   @db.VarChar(500)
  // FIX: Decimal for lat/lng
  lat        Decimal?  @db.Decimal(9, 6)
  lng        Decimal?  @db.Decimal(9, 6)

  openingHours Json?

  totalListings  Int     @default(0)
  activeListings Int     @default(0)
  totalReviews   Int     @default(0)
  // FIX: Decimal(3,2) — e.g. 4.75; Float is imprecise for display
  averageRating  Decimal @default(0) @db.Decimal(3, 2)
  // FIX: BigInt for high-traffic dealer profiles
  totalViews     BigInt  @default(0)
  responseRate   Decimal @default(0) @db.Decimal(5, 2)
  responseTimeMin Int?

  specialties String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  showroomImages  ShowroomImage[]
  reviews         DealerReview[]
  analytics       DealerAnalytic[]
  subscription    DealerSubscription?
  contactRequests DealerContactRequest[]
  badges          DealerBadge[]
  followers       DealerFollower[]

  // CHANGE: marketplace browse composite — status + tier + rating
  @@index([status, tier, averageRating(sort: Desc)])
  @@index([locationId, status])
  @@index([slug])
  // ADDED: userId lookup — resolves dealer profile from auth context
  @@index([userId])
  // ADDED: status alone — admin "pending verification" queue
  @@index([status, createdAt(sort: Desc)])
  // Trigram indexes on dealer names for autocomplete — created in raw migration
  @@map("dealers")
}

