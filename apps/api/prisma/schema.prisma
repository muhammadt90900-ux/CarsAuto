// ─────────────────────────────────────────────────────────────────────────────
// UPLOADED FILE (ownership registry — F7 fix)
// Persists upload ownership in the database so IDOR checks survive
// process restarts and scale-out. Previously tracked only in CacheService
// (in-process Map), which reset on every restart and was not shared across
// replicas, causing the ownership check to silently fail-open after any deploy.
// ─────────────────────────────────────────────────────────────────────────────

model UploadedFile {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  filename  String   @unique @db.VarChar(512)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("uploaded_files")
}

// ─────────────────────────────────────────────────────────────────────────────
// SEARCH EVENT (Search Architecture Phase 2)
// One row per tracked search query (see SearchService.trackSearchEvent(),
// called fire-and-forget from search()). High write volume, append-only,
// never updated — same partitioning candidate as AuditLog if volume grows
// (not partitioned yet; revisit if this table becomes a hot-write
// bottleneck, per PARTITIONING-RUNBOOK.md's criteria). Powers Phase 4's
// trending-searches feature; not read by anything yet in this phase.
// No foreign-key-enforced relation to User — userId is nullable and
// intentionally NOT a relation field, so this table's writes are never
// blocked by (or need to cascade with) user deletion.
// ─────────────────────────────────────────────────────────────────────────────

model SearchEvent {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  query       String   @db.VarChar(200)
  locale      String   @db.VarChar(8)
  resultCount Int      @map("result_count")
  userId      String?  @db.Uuid @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Search Architecture Phase 4: the (up to 20) listing IDs shown for this
  // search — the "impressions" half of the CTR calculation in
  // ranking-formula.ts. `has`/`hasSome` Prisma filters and Postgres's
  // native `= ANY(...)` both work directly against this without a join
  // table; ranking-recompute.processor.ts's nightly batch instead uses a
  // raw `unnest()` GROUP BY for the aggregate case (see that file) since
  // it needs a per-listing count across ALL rows, not a single lookup.
  resultListingIds String[] @default([]) @map("result_listing_ids")

  clicks      SearchClick[]

  @@index([query])
  @@index([createdAt])
  @@map("search_events")
}

// Search Architecture Phase 4: one row per click on a search result card
// (POST /search/click, called by the frontend — see
// SearchService.recordClick()). Paired with SearchEvent.resultListingIds
// to compute per-listing CTR (ranking-formula.ts). searchEventId is a
// real relation (onDelete: SetNull, not Cascade) — a click is still a
// meaningful signal for the listing's CTR even if its parent search_event
// row is ever pruned, so it deliberately isn't deleted along with it.
model SearchClick {
  id            String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  searchEventId String?      @db.Uuid @map("search_event_id")
  searchEvent   SearchEvent? @relation(fields: [searchEventId], references: [id], onDelete: SetNull)
  listingId     String       @db.Uuid @map("listing_id")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([listingId, createdAt])
  @@map("search_clicks")
}
