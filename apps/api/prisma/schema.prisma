  PAST_DUE
  CANCELLED
  TRIALING
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS — payments / moderation / chat / dealer inbox
//
// F-MED fix: these 5 enums replace plain-`String` status/gateway columns
// that previously had NO database-level constraint — any string (a typo, an
// old/renamed value, garbage from a bug) could be written and would sit
// there silently. Application code already enforced these values at the
// TypeScript layer in most call sites (see PaymentStatus/PaymentGateway in
// payments/dto/payment.dto.ts, now re-exported from @prisma/client instead
// of being a second, independently-maintained source of truth), but nothing
// stopped a raw SQL script, a different service, or a future bug from
// writing an invalid value straight into the column.
//
// ⚠️ MIGRATION NOTE — READ BEFORE RUNNING `npx prisma db push`:
// This project uses `db push`, not `migrate dev` (no prisma/migrations/
// directory exists). `db push` converts a column's type via
// `ALTER COLUMN ... TYPE "EnumName" USING column::text::"EnumName"` — that
// USING cast fails outright if ANY existing row's value isn't an exact
// (case-sensitive) match for one of the new enum's labels.
//
// The existing string values in this codebase are lowercase
// ('pending', 'active', 'new', 'stripe', ...) while every enum below uses
// uppercase labels (matching every other enum already in this schema —
// ListingStatus, DealerStatus, etc.). That means `db push` WILL fail on a
// populated database unless you uppercase the existing data first.
//
// Run apps/api/prisma/migrations-manual/2026-06-status-enums.sql (included
// alongside this schema change) BEFORE `npx prisma db push`. It:
//   1. Prints any row whose value won't survive the uppercase+enum-cast
//      (so you can fix genuine bad data — typos, stale values — by hand)
//   2. UPPER()-cases the four affected columns
//   3. Is safe to re-run (idempotent — UPPER('PENDING') = 'PENDING')
//
// Subscription.status (per-user subscription, distinct from
// DealerSubscription.status) is INTENTIONALLY left as a plain String — see
// the existing comment on that field. Do not enum-ify it as part of this
// change; that was a deliberate prior decision, not an oversight.

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentGateway {
  STRIPE
  ZAINCASH
  FASTPAY
  QICARD
  ASIAHAWALA
  ALIPAY
  WECHATPAY
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum ContactRequestStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// CHANGE: added phone unique constraint, index on role, index on googleId/appleId
//         for OAuth lookups, added deletedAt for soft-delete
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  // NOTE (Prompt 3.3): this @unique is case-sensitive at the Prisma/DB
  // level and is kept only so `findUnique({ where: { email } })` keeps
  // type-checking across the codebase. The actual case-insensitive
  // uniqueness guarantee is a separate functional UNIQUE index on
  // LOWER(email), added via raw migration
  // 20260703081800_case_insensitive_user_email (Prisma can't express
  // functional indexes natively). All write paths also normalize email
  // to lowercase before it reaches Prisma — see RegisterDto/LoginDto/
  // ForgotPasswordDto and AuthService — so in practice values stored
  // here are already lowercase; the DB index is the belt-and-suspenders
  // backstop for any path that doesn't go through those DTOs.
  email     String   @unique
  // FIX: phone should be unique if stored; use partial unique for non-null
  phone     String?
  password  String?
  name      String
  avatar    String?
  bio       String?  @db.VarChar(500)  // FIX 3: user bio field
  role      UserRole @default(USER)
  verified  Boolean  @default(false)
  locale    String   @default("ku") @db.VarChar(5)
  googleId  String?  @unique
  appleId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // ADDED: soft-delete support
  deletedAt DateTime?

  // Security fields
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  passwordChangedAt   DateTime?
  banned              Boolean   @default(false)
  suspendedUntil      DateTime?
  suspendedReason     String?   @db.VarChar(255)
  
  listings               Listing[]
  chatsAsBuyer           Chat[]                  @relation("BuyerChats")
  chatsAsSeller          Chat[]                  @relation("SellerChats")
  messages               Message[]
  notifications          Notification[]
  reviewsGiven           Review[]                @relation("Reviewer")
  reviewsReceived        Review[]                @relation("Reviewee")
  payments               Payment[]
  subscription           Subscription?
  reports                Report[]
  refreshTokens          RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  auditLogs               AuditLog[]
  dealer                 Dealer?
  dealerReviews          DealerReview[]          @relation("DealerReviewer")
  messageReadReceipts    MessageReadReceipt[]
  dealerContacts         DealerContactRequest[]  @relation("DealerContacts")
  favorites              Favorite[]
  savedSearches          SavedSearch[]
  pushSubscriptions      PushSubscription[]
  uploads                Upload[]
  notificationPreference NotificationPreference?
  followedDealers        DealerFollower[]
  uploadedFiles          UploadedFile[]
  aiUsageLogs            AiUsageLog[]
  aiChatSessions         AiChatSession[]
  fraudScore             FraudScore?
  sellerScore            SellerScore?

  // role index for admin queries; partial indexes on banned/locked/deleted handled in migration
  @@index([role])
  @@index([createdAt])
  // ADDED: locale index — used when broadcasting locale-specific notifications
  @@index([locale])
  // ADDED: banned + role composite — admin "banned users" page filters both
  @@index([banned, role])
  // deletedAt partial index, phone partial unique, lockedUntil partial index
  // all handled in raw migration SQL (Prisma cannot express partial indexes)
}

// ─────────────────────────────────────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // SHA-256(rawToken)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  // CHANGE: partial index for non-expired tokens — handled in migration
  // CHANGE: expiresAt index for cleanup jobs
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// EMAIL VERIFICATION TOKEN
// One active token per user; old tokens are replaced on resend.
// ─────────────────────────────────────────────────────────────────────────────

model EmailVerificationToken {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // SHA-256(rawToken)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// PASSWORD RESET TOKEN
// One active token per user; old tokens replaced on re-request.
// Token is single-use: consumed immediately on successful reset.
// ─────────────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // SHA-256(rawToken) — never store raw
  expiresAt DateTime
  usedAt    DateTime? // set when consumed; token invalid after this
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG
// Append-only record of security-sensitive events.
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  // PARTITIONED IN PRODUCTION (Phase 2 / Prompt 2.3, once
  // migrations-manual/partition-audit-logs.sql has been run) — monthly
  // RANGE partitions on "createdAt". Do NOT run `prisma db push`
  // destructively against this table; use the manual migration process in
  // apps/api/prisma/migrations-manual/PARTITIONING-RUNBOOK.md.
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  // Who performed the action (null = anonymous/system)
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorId    String?  @db.Uuid           @map("actor_id")
  // What was affected
  targetId   String?  @db.Uuid           @map("target_id")
  targetType String?  @db.VarChar(50)    @map("target_type")
  // Action performed
  action     String   @db.VarChar(100)
  // Request context
  ip         String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(512)   @map("user_agent")
  traceId    String?  @db.VarChar(36)    @map("trace_id")
  requestId  String?  @db.VarChar(36)    @map("request_id")
  // State diff
  before     String?  @db.Text           @map("before_json")
  after      String?  @db.Text           @map("after_json")
  metadata   String?  @db.Text
  // DEPRECATED (Prompt 3.2, 2026-07-03): no remaining writers in the
  // codebase as of this change — auth.service.ts's writeAuditLog() was
  // the only writer and now writes `metadata` instead. Historical rows
  // are backfilled into `metadata` via migration
  // 20260703081500_backfill_auditlog_meta_to_metadata.
  // Safe to drop this column once BOTH are true:
  //   1. The backfill migration has been run in every environment
  //      (dev/staging/prod), and
  //   2. At least ~30 days have passed with no new `meta` writes
  //      (grep the codebase for `\.meta\b` under AuditLog context to
  //      re-confirm before dropping — don't rely on this comment alone).
  // Do not read from `meta` in new code.
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([actorId])
  @@index([action, createdAt(sort: Desc)])
  @@index([targetId, targetType, createdAt(sort: Desc)])
  @@index([traceId])
  @@index([ip])
  @@index([userId, action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRICE CURVE
// ADDED (Prompt 7 — Price Feedback Loop): nightly-computed depreciation
// curve per (brand, bodyType, country, yearBucket), from SOLD listings
// only (status = SOLD AND soldPrice IS NOT NULL). Used ONLY as an
// additional sanity-check signal in AiService.suggestPrice — never
// replaces the existing IQR/median comparable-based logic. See
// AiService.suggestPrice's updated header comment for the minimum
// sampleSize threshold below which a row here is ignored.
// ─────────────────────────────────────────────────────────────────────────────

model PriceCurve {
  id                 String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  brandId            String   @db.Uuid
  brand              CarBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  bodyType           BodyType
  // NOTE: matches Location.country's format (free-text country NAME, e.g.
  // "Iraq") — NOT CarBrand.countryCode's ISO 3166-1 alpha-2 format. There
  // is no country-name → ISO2 mapping anywhere in this schema, so the
  // worker job groups by whatever string is already sitting in
  // Location.country rather than inventing a lookup table for this one
  // feature. If Location.country ever gets normalized to ISO2, this
  // column should follow it — flagging the inconsistency rather than
  // quietly picking one.
  country            String   @db.VarChar(100)
  yearBucket         Int      // e.g. vehicle model year, bucketed (see worker job comment)
  avgDepreciationPct Float    // average % below original/comparable price at this age
  sampleSize         Int
  lastComputedAt     DateTime @default(now())

  @@unique([brandId, bodyType, country, yearBucket])
  @@map("price_curves")
}

// ─────────────────────────────────────────────────────────────────────────────
// SELLER SCORE
// ADDED (Prompt 5 — Seller Behavior Scoring): one row per user, overwritten
// on each recompute — same "current state, not history" reasoning as
// FraudScore. narrativeEn/Ku/Ar follow the same per-locale reasoning
// pattern PriceSuggestion already uses in ai.service.ts (no narrativeZh
// there either, despite Chinese being a supported locale — matching that
// existing gap rather than fixing it silently here).
// ─────────────────────────────────────────────────────────────────────────────

model SellerScore {
  id                        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId                    String   @unique @db.Uuid
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avgResponseMinutes        Float?   // null = no message history to measure
  listingQualityScore       Int      // 0-100
  priceCompetitivenessScore Int      // 0-100 (100 = priced at/below market)
  reportRateScore           Int      // 0-100 (100 = worst / highest report rate)
  overallScore              Int      // 0-100
  narrativeEn               String?  @db.Text
  narrativeKu                String? @db.Text
  narrativeAr                String? @db.Text
  computedAt                DateTime @default(now())

  @@index([overallScore(sort: Desc)])
  @@map("seller_scores")
}

// ─────────────────────────────────────────────────────────────────────────────
// DEALER LEAD SCORE
// ADDED (Prompt 5 — Dealer Lead Scoring): one row per DealerContactRequest,
// computed once shortly after creation (not continuously re-scored — a
// lead's "hotness" at time of contact is what a dealer needs to triage
// their inbox, see LeadScoringService's header comment for the known gap
// this implies).
// ─────────────────────────────────────────────────────────────────────────────

model DealerLeadScore {
  id               String               @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  contactRequestId String               @unique @db.Uuid
  contactRequest   DealerContactRequest @relation(fields: [contactRequestId], references: [id], onDelete: Cascade)
  score            Int                  // 0-100, higher = hotter lead
  reasons          Json
  narrativeEn      String?              @db.Text
  narrativeKu      String?              @db.Text
  narrativeAr      String?              @db.Text
  computedAt       DateTime             @default(now())

  @@index([score(sort: Desc)])
  @@map("dealer_lead_scores")
}

// ─────────────────────────────────────────────────────────────────────────────
// FRAUD SCORE
// ADDED (Prompt 4 — Account Risk Scoring): one row per user, overwritten on
// each recompute (nightly batch + on-demand admin recompute) rather than an
// append-only history table — admin needs "what's the risk RIGHT NOW",
// not a full audit trail of every past score. If a historical trend view is
// wanted later, that's an additive AiUsageLog-style append table, not a
// change to this one.
//
// KNOWN GAPS (flagged, not silently worked around — see FraudScoringService
// header comment for detail): no IP-address field exists anywhere in this
// schema (Payment, User, TransactionLog all lack one), and there's no
// chargeback/dispute tracking model. Two signals a fraud system would
// normally use (IP velocity/mismatch, chargeback rate) are NOT included in
// `signals` below because the underlying data doesn't exist yet.
// ─────────────────────────────────────────────────────────────────────────────

model FraudScore {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId       String   @unique @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  overallRisk  Int      // 0-100
  signals      Json     // breakdown: { signal_name: { score, detail } } — see FraudScoringService
  computedAt   DateTime @default(now())

  // Admin fraud queue: "show me the riskiest accounts first"
  @@index([overallRisk(sort: Desc)])
  @@map("fraud_scores")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI CHAT SESSION / MESSAGE
// ADDED (Prompt 3 — Buyer-Facing AI Chat Assistant): deliberately NOT the
// same tables as Chat/Message above — those are human-to-human buyer↔seller
// chat; this is a separate concern (one visitor talking to the assistant).
// userId is nullable — anonymous visitors can use the assistant without an
// account (soft-verified from a bearer token when present; see
// AiChatController's extractOptionalUserId()).
// ─────────────────────────────────────────────────────────────────────────────

model AiChatSession {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  locale    String   @default("ku") @db.VarChar(8)
  createdAt DateTime @default(now())
  expiresAt DateTime

  messages  AiChatMessage[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("ai_chat_sessions")
}

enum AiChatRole {
  user
  assistant
}

model AiChatMessage {
  id        String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  sessionId String        @db.Uuid
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      AiChatRole
  content   String        @db.Text
  createdAt DateTime      @default(now())

  // History pagination: fetch a session's turns in order.
  @@index([sessionId, createdAt(sort: Asc)])
  @@map("ai_chat_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI USAGE LOG
// ADDED (AI Gateway Foundation, Prompt 1): append-only log of every LLM call
// made through OpenAiService (embed/complete/moderate), written by
// AiCostTrackerService. userId is nullable — background jobs (nightly
// scoring, translation queue workers) have no request-scoped user.
// Decimal(10,6) — NOT (12,2) like Payment/monetary tables — because a
// single call often costs a fraction of a cent; (12,2) would round every
// row to 0.00 and defeat the purpose of cost tracking.
// ─────────────────────────────────────────────────────────────────────────────

model AiUsageLog {
  id               String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  feature          String   @db.VarChar(100)
  model            String   @db.VarChar(100)
  userId           String?  @db.Uuid
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  estimatedCostUsd Decimal  @db.Decimal(10, 6)
  createdAt        DateTime @default(now())

  // Cost dashboards / admin reporting group by feature and by day.
  @@index([feature, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([model, createdAt(sort: Desc)])
  @@map("ai_usage_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAR REFERENCE TABLES
// CHANGE: @db.Uuid on all FKs; added isActive filter index; @@map for
//         lower_snake table names to match SQL conventions
// ─────────────────────────────────────────────────────────────────────────────

model CarBrand {
  id          String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug        String  @unique @db.VarChar(100)
  nameEn      String  @db.VarChar(100)
  nameAr      String  @db.VarChar(100)
  nameKu      String  @db.VarChar(100)
  nameZh      String  @db.VarChar(100)
  logoUrl     String?
  countryCode String  @db.Char(2) // ISO 3166-1 alpha-2
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  models              CarModel[]
  listingSpecs        ListingVehicleSpec[]
  partCompatibilities PartCompatibility[]
  priceCurves         PriceCurve[]

  // CHANGE: composite partial index — only active brands matter for searches
  @@index([isActive, slug])
  @@index([countryCode])
  // F-PERF fix: nameEn/nameKu GIN trigram indexes for autocomplete/search
  // ILIKE queries are in
  // prisma/migrations-manual/2026-07-pg-trgm-search-indexes.sql.
  @@map("car_brands")
}

model CarModel {
  id       String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  brandId  String   @db.Uuid
  brand    CarBrand @relation(fields: [brandId], references: [id], onDelete: Restrict)
  slug     String   @db.VarChar(100)
  nameEn   String   @db.VarChar(100)
  nameAr   String   @db.VarChar(100)
  nameKu   String   @db.VarChar(100)
  nameZh   String   @db.VarChar(100)
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generations         CarModelGeneration[]
  listingSpecs        ListingVehicleSpec[]
  partCompatibilities PartCompatibility[]

  @@unique([brandId, slug])
  // CHANGE: composite — brand + active used in dropdowns
  @@index([brandId, isActive])
  // F-PERF fix: nameEn/nameKu GIN trigram indexes for autocomplete/search
  // ILIKE queries are in
  // prisma/migrations-manual/2026-07-pg-trgm-search-indexes.sql.
  @@map("car_models")
}

model CarModelGeneration {
  id       String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  modelId  String   @db.Uuid
  model    CarModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  name     String?  @db.VarChar(100)
  yearFrom Int      @db.SmallInt
  yearTo   Int?     @db.SmallInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trims CarTrim[]

  @@index([modelId])
  // CHANGE: year range queries — supports "which generation covers year X"
  @@index([yearFrom, yearTo])
  @@map("car_model_generations")
}

model CarTrim {
  id           String             @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  generationId String             @db.Uuid
  generation   CarModelGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  name         String             @db.VarChar(100)
  bodyType     BodyType
  fuelType     FuelType
  transmission TransmissionType
  drivetrain   DrivetrainType
  // FIX: engineCC should be SmallInt (max 65535 cc — more than enough)
  engineCC     Int?               @db.SmallInt
  engineLabel  String?            @db.VarChar(50)
  // FIX: powerKw SmallInt — max 32767 kW covers any production car
  powerKw      Int?               @db.SmallInt
  doors        Int?               @db.SmallInt
  seats        Int?               @db.SmallInt
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  listingSpecs ListingVehicleSpec[]

  // CHANGE: composite — generation + active avoids filtering after join
  @@index([generationId, isActive])
  // CHANGE: composite for spec-match searches
  @@index([bodyType, fuelType, drivetrain])
  @@map("car_trims")
}

// ─────────────────────────────────────────────────────────────────────────────
// LISTING VEHICLE SPEC
// CHANGE: mileageKm → Int (was nullable Float in some schemas); composite
//         indexes aligned to real filter query patterns; added CHECK constraints
//         via raw SQL in migration; vin unique constraint added
// ─────────────────────────────────────────────────────────────────────────────

model ListingVehicleSpec {
  id        String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  listingId String  @unique @db.Uuid
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  trimId  String?  @db.Uuid
  trim    CarTrim? @relation(fields: [trimId], references: [id], onDelete: SetNull)

  brandId String?   @db.Uuid
  brand   CarBrand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  modelId String?   @db.Uuid
  model   CarModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)

  // FIX: year SmallInt — e.g. 1900–2100 fits in 2 bytes
  year         Int?             @db.SmallInt
  bodyType     BodyType?
  fuelType     FuelType?
  transmission TransmissionType?
  drivetrain   DrivetrainType?
  engineCC     Int?             @db.SmallInt
  engineLabel  String?          @db.VarChar(50)
  powerKw      Int?             @db.SmallInt
  doors        Int?             @db.SmallInt
  seats        Int?             @db.SmallInt
  condition    ListingCondition?
  // FIX: mileageKm Int (was Float — km has no fractional part)
  mileageKm    Int?
  color        String?          @db.VarChar(50)
  // CHANGE: vin unique (partial, where non-null) — enforced in raw SQL migration
  vin          String?          @db.VarChar(17)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // CHANGE: primary search filter — brand+model+year is the most common combo
  @@index([brandId, modelId, year])
  // CHANGE: secondary filter — type+condition+fuel used in CAR searches
  @@index([fuelType, bodyType, drivetrain])
  // ADDED: transmission filter — "Automatic SUVs" is a common search combo
  @@index([transmission, bodyType])
  // CHANGE: mileage range filter (separate — low selectivity if combined)
  @@index([mileageKm])
  // CHANGE: condition alone for "NEW cars" page
  @@index([condition])
  // trimId for exact trim lookups
  @@index([trimId])
  // ADDED: year alone — "show me all 2022 cars" browse pattern
  @@index([year])
  @@map("listing_vehicle_specs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PART COMPATIBILITY
// ─────────────────────────────────────────────────────────────────────────────

model PartCompatibility {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  listingId String    @db.Uuid
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  brandId   String?   @db.Uuid
  brand     CarBrand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  modelId   String?   @db.Uuid
  model     CarModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)
  yearFrom  Int?      @db.SmallInt
  yearTo    Int?      @db.SmallInt
  notes     String?

  // CHANGE: composite — all three together cover "find parts for brand+model+year"
  @@index([listingId, brandId, modelId])
  @@index([brandId, modelId])
  // ADDED: year range queries — "find parts for 2018-2022 Camry"
  @@index([brandId, modelId, yearFrom, yearTo])
  @@map("part_compatibilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// LISTING
// CHANGE: price → Decimal(12,2) — Float is lossy for monetary values;
//         added searchVector computed column (maintained by trigger);
//         added featuredUntil index; composite indexes for common queries;
//         views → BigInt for long-lived high-traffic listings;
//         categoryId added to composite for category-scoped searches
// ─────────────────────────────────────────────────────────────────────────────

model Listing {
  id     String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  type   ListingType
  status ListingStatus @default(ACTIVE)
  userId String        @db.Uuid
  user   User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  // DEPRECATED (2026-07-03, Phase 2 / Prompt 2.2): superseded by the
  // ListingTranslation model below. Kept in place — NOT dropped — for one
  // full release cycle so we can verify ListingTranslation is correct in
  // production before a follow-up migration drops these 8 columns. Do NOT
  // read/write these directly in new code — use `translations` instead.
  // See prisma/migrations-manual/backfill-listing-translations.ts for the
  // one-time backfill, and the Phase 2 audit notes for the checklist to run
  // before the follow-up drop migration.
  //
  // F-PERF fix: GIN trigram indexes for the ILIKE '%term%' search these 3
  // columns still take (search.service.ts, listings.service.ts
  // buildWhereClause()) are in
  // prisma/migrations-manual/2026-07-pg-trgm-search-indexes.sql — not
  // expressible as a Prisma @@index (no operator-class support in the
  // schema DSL). Drop those 3 indexes in the same follow-up migration that
  // drops these columns.
  titleKu       String  @db.VarChar(255)
  titleAr       String  @db.VarChar(255)
  titleEn       String  @db.VarChar(255)
  titleZh       String  @db.VarChar(255)
  descriptionKu String? @db.Text
  descriptionAr String? @db.Text
  descriptionEn String? @db.Text
  descriptionZh String? @db.Text

  // ADDED (Phase 2 / Prompt 2.2): normalized per-locale title/description,
  // replacing the 8 flat columns above so adding a 5th language doesn't
  // require another schema migration + 8-column bloat on the hottest table.
  translations ListingTranslation[]

  // FIX: Decimal(12,2) prevents floating-point rounding on monetary values
  price      Decimal @db.Decimal(12, 2)
  currency   String  @default("USD") @db.Char(3)
  negotiable Boolean @default(false)

  // ADDED (Prompt 7 — Price Feedback Loop): set when status transitions to
  // SOLD via ListingsService.markSold(). Nullable — most listings never
  // reach this. soldAt is set server-side (new Date()) at transition time,
  // never trusted from client input — see markSold()'s comment for why.
  soldPrice Decimal? @db.Decimal(12, 2)
  soldAt    DateTime?

  locationId String?   @db.Uuid
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  categoryId String?   @db.Uuid
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  partNumber String? @db.VarChar(100)

  // FIX: BigInt for views — popular listings can exceed Int max (2.1B)
  views         BigInt    @default(0)
  featured      Boolean   @default(false)
  featuredUntil DateTime?

  // Search Architecture Phase 4: multi-factor ranking score used as
  // Meilisearch's secondary sort tiebreaker (after text-match relevance,
  // before createdAt) — see search-indexing/ranking-formula.ts for the
  // exact formula. Recomputed nightly for all ACTIVE listings
  // (ranking-recompute.processor.ts) and once immediately on
  // create/update (search-index.processor.ts) so a brand-new listing
  // isn't stuck at the default until the next nightly run.
  rankingScore  Float     @default(1.0) @map("ranking_score")

  // ADDED: soft-delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FEATURE 2: pgvector embedding for semantic search (nullable — populated by background job)
  // Index created in raw migration: 20240101_add_embedding/migration.sql
  embedding Unsupported("vector(1536)")?

  vehicleSpec       ListingVehicleSpec?
  accessorySpec     ListingAccessorySpec?
  partCompatibility PartCompatibility[]
  images            Image[]
  chats             Chat[]
  favorites         Favorite[]

  // ── Composite indexes ordered by selectivity ──────────────────────────────

  // Primary browse: status + type + createdAt (most pages filter by both)
  @@index([status, type, createdAt(sort: Desc)])
  // User's own listings page
  @@index([userId, status, createdAt(sort: Desc)])
  // Location-scoped browse
  @@index([locationId, status, type])
  // Category browse
  @@index([categoryId, status, createdAt(sort: Desc)])
  // Price range filter (after status filter)
  @@index([status, price])
  // Featured listings — partial index created in raw migration
  @@index([featured, featuredUntil])
  // Soft-delete — partial index created in raw migration
  @@index([deletedAt])
  // ADDED: partNumber lookup — spare parts sellers search by OEM part number
  @@index([partNumber])
  // ADDED: currency index — multi-currency marketplace regional browse
  @@index([currency, status])
  // ADDED: negotiable filter — "negotiable only" browse toggle
  @@index([negotiable, status])
  // Full-text search vectors — GIN indexes created in raw migration
  @@map("listings")
}

// ─────────────────────────────────────────────────────────────────────────────
// LISTING TRANSLATION
// ADDED (Phase 2 / Prompt 2.2): normalizes titleKu/titleAr/titleEn/titleZh +
// descriptionKu/descriptionAr/descriptionEn/descriptionZh off the Listing
// table into one row per (listing, locale). Adding a 5th language becomes a
// data change, not a schema migration.
//
// NOTE (search architecture): apps/api/src/modules/search/search.service.ts
// currently runs ILIKE / full-text queries directly against the legacy
// titleKu/titleAr/titleEn columns and their GIN indexes. Those read paths
// are DELIBERATELY NOT switched to this table in Prompt 2.2 — doing so
// before the full-text GIN indexes are rebuilt against ListingTranslation
// would silently degrade search relevance/ranking. That is tracked as a
// separate follow-up once this table is verified correct in production.
// ─────────────────────────────────────────────────────────────────────────────

model ListingTranslation {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  listingId String   @db.Uuid
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  locale      String  @db.VarChar(5) // "ku" | "ar" | "en" | "zh"
  title       String  @db.VarChar(255)
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listingId, locale])
  // Covering lookup index — "get this listing's title in locale X"
  @@index([listingId, locale])
  @@map("listing_translations")
}

// ─────────────────────────────────────────────────────────────────────────────
// IMAGE
// CHANGE: added order + isCover composite; listingId + isCover partial
// ─────────────────────────────────────────────────────────────────────────────

model Image {
  id        String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
