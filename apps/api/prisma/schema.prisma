// ─────────────────────────────────────────────────────────────────────────────
// AutoBazaarPro — Optimized Prisma Schema
// Architect review: 2026-05-31
// Changes: composite indexes, partial indexes, full-text search columns,
//          ULID PKs, numeric type fixes, constraint additions, soft-delete,
//          search vector columns, denorm columns, missing FK cascades.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch" , "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

