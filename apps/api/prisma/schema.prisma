  @@index([reporterId])
  // CHANGE: composite — admin moderation queue filters by status + type
  @@index([status, targetType, createdAt(sort: Desc)])
  @@map("reports")
}

// ─────────────────────────────────────────────────────────────────────────────
// FAVORITE
