  listingId String  @db.Uuid
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  isCover   Boolean @default(false)
  order     Int     @default(0) @db.SmallInt
  // Feature: 360° Photo Set — 'standard' | '360_view'. Plain string (not enum)
  // to avoid the TS2719 class of bugs from hand-mirrored Prisma enums in
  // common/prisma/enums.ts.
  tag       String  @default("standard") @db.VarChar(20)

  // CHANGE: composite — fetch all images for a listing sorted by order
  @@index([listingId, order])
  @@map("images")
}

// ─────────────────────────────────────────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id       String     @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  parentId String?    @db.Uuid
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("SubCategories")
  nameKu   String     @db.VarChar(100)
  nameAr   String     @db.VarChar(100)
  nameEn   String     @db.VarChar(100)
  nameZh   String     @db.VarChar(100)
  icon     String?
  slug     String     @unique @db.VarChar(100)
  listings Listing[]

  // CHANGE: parentId index for tree traversal
  @@index([parentId])
  @@map("categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOCATION
// CHANGE: lat/lng → Decimal(9,6) for geo precision; composite index on
//         country+governorate for region filtering
// ─────────────────────────────────────────────────────────────────────────────

model Location {
  id          String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  country     String  @db.VarChar(100)
  governorate String? @db.VarChar(100)
  city        String  @db.VarChar(100)
  nameKu      String  @db.VarChar(100)
  nameAr      String  @db.VarChar(100)
  nameEn      String  @db.VarChar(100)
  nameZh      String  @db.VarChar(100)
  // FIX: Decimal(9,6) = ±180.000000 — sufficient for GPS, avoids Float drift
  lat         Decimal @db.Decimal(9, 6)
  lng         Decimal @db.Decimal(9, 6)
  listings    Listing[]
  dealers     Dealer[]

  // CHANGE: composite country+governorate for region dropdowns
  @@index([country, governorate])
  @@index([city])
  @@map("locations")
}

// ─────────────────────────────────────────────────────────────────────────────
// CHAT
// CHANGE: unique constraint (listingId, buyerId) to prevent duplicate chats;
//         status → enum instead of raw String
// ─────────────────────────────────────────────────────────────────────────────

model Chat {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  listingId String   @db.Uuid
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String   @db.Uuid
  buyer     User     @relation("BuyerChats", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  String   @db.Uuid
  seller    User     @relation("SellerChats", fields: [sellerId], references: [id], onDelete: Cascade)
  status    ChatStatus @default(ACTIVE)
  messages  Message[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // CHANGE: prevent duplicate chats between same buyer+listing
  @@unique([listingId, buyerId])
  // CHANGE: inbox queries — user sees their chats ordered by latest activity
  @@index([buyerId, updatedAt(sort: Desc)])
  @@index([sellerId, updatedAt(sort: Desc)])
  // ADDED: status filter — "archived" or "active" chat inbox tab
  @@index([buyerId, status, updatedAt(sort: Desc)])
  @@index([sellerId, status, updatedAt(sort: Desc)])
  // ADDED: listing chats — admin/seller sees all chats for a listing
  @@index([listingId, createdAt(sort: Desc)])
  @@map("chats")
}

// ─────────────────────────────────────────────────────────────────────────────
// MESSAGE
// CHANGE: chatId + createdAt composite for pagination; partial index for
//         unread messages; readAt partial index handled in migration
// ─────────────────────────────────────────────────────────────────────────────

model Message {
  // PARTITIONED IN PRODUCTION (Phase 2 / Prompt 2.3, once
  // migrations-manual/partition-messages.sql has been run) — monthly RANGE
  // partitions on "createdAt". Do NOT run `prisma db push` destructively
  // against this table; use the manual migration process documented in
  // apps/api/prisma/migrations-manual/PARTITIONING-RUNBOOK.md. Also see
  // that runbook for why message_read_receipts.messageId's FK to this
  // table needed special handling.
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  chatId    String    @db.Uuid
  chat      Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String    @db.Uuid
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Restrict)
  content   String    @db.Text
  type      String    @default("text") @db.VarChar(20)

  // ── Voice note fields (Feature 6) ──────────────────────────────────────────
  messageType   String   @default("text") @db.VarChar(20) // text | image | voice | system
  audioUrl      String?  @db.VarChar(500)
  audioDuration Int? // seconds

  mediaUrl  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  readReceipts MessageReadReceipt[]

  // CHANGE: chat thread pagination — most common query
  @@index([chatId, createdAt(sort: Desc)])
  // senderId for "messages I sent" queries
  @@index([senderId])
  // ADDED: voice-note filtering within a chat thread
  @@index([messageType, chatId])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION
// CHANGE: partial index for unread only; composite userId+createdAt for feed
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  // PARTITIONED IN PRODUCTION (Phase 2 / Prompt 2.3, once
  // migrations-manual/partition-notifications.sql has been run) — monthly
  // RANGE partitions on "createdAt". Do NOT run `prisma db push`
  // destructively against this table; use the manual migration process in
  // apps/api/prisma/migrations-manual/PARTITIONING-RUNBOOK.md.
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  body      String   @db.Text
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // CHANGE: unread notifications partial index in migration
  @@index([userId, createdAt(sort: Desc)])
  // ADDED: type filter — "show only PRICE_DROP notifications"
  @@index([userId, type, createdAt(sort: Desc)])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// REVIEW
// CHANGE: rating CHECK constraint (1-5) in raw migration; unique reviewer per
//         reviewee enforced; added composite for rating aggregation
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  reviewerId String   @db.Uuid
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId String   @db.Uuid
  reviewee   User     @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  rating     Int      @db.SmallInt
  comment    String   @db.Text
  createdAt  DateTime @default(now())

  // CHANGE: prevent duplicate reviews; reviewer per reviewee
  @@unique([reviewerId, revieweeId])
  // CHANGE: composite for average rating queries
  @@index([revieweeId, rating])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT
// CHANGE: amount → Decimal(12,2); status → enum-like (use varchar for now);
//         composite userId+createdAt for billing history
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id             String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId         String    @db.Uuid
  user           User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  plan           String    @db.VarChar(50)
  amount         Decimal   @db.Decimal(12, 2)
  currency       String    @db.Char(3)
  status         PaymentStatus

  // Gateway fields
  gateway        PaymentGateway @default(STRIPE)
  gatewayId      String?   @unique @db.VarChar(255)
  gatewayStatus  String?   @db.VarChar(50)

  // Recovery / retry
  retryCount     Int       @default(0)
  nextRetryAt    DateTime?
  failureReason  String?   @db.Text

  // Refund tracking
  refundedAt     DateTime?
  refundAmount   Decimal?  @db.Decimal(12, 2)

  metadata       Json?

  // F1.4: FX rate capture — CarsAuto now takes payments in USD/IQD/EUR/GBP/
  // AED/CNY (see PaymentCurrency in payment.dto.ts) while the business
  // settles in a single currency. Rate is captured at transaction time (not
  // looked up later) because rates move and a payment's USD value must
  // reflect what it was actually worth *when it happened*, not today.
  //   exchangeRateToUsd — 1 unit of `currency` = this many USD, as of createdAt.
  //   settlementCurrency — currency actually settled into the business's bank
  //     account for this payment (may differ from `currency`, the currency
  //     the customer paid in — e.g. gateway auto-converts to USD on payout).
  //   amountUsd — amount * exchangeRateToUsd, computed and stored once at
  //     write time (see PaymentsService.computeAmountUsd) so revenue
  //     reporting queries never redo this math ad hoc. Not a DB-generated
  //     column — see the note in migrations-manual/f1_4_*.sql for why.
  // All three are nullable: historical rows predate this feature, and a
  // transient FX-provider failure must never block a payment from being
  // recorded (ExchangeRateService returns null rather than throwing).
  exchangeRateToUsd  Decimal? @db.Decimal(18, 8)
  settlementCurrency String?  @db.Char(3)
  amountUsd          Decimal? @db.Decimal(20, 8)

  // F1.3: optimistic locking — Stripe (and regional gateway) webhook
  // retries can deliver overlapping events for the same payment; two
  // concurrent status-transition writes must not silently last-write-wins
  // each other. See PaymentsService's version-guarded update helper.
  version        Int       @default(0)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactionLogs TransactionLog[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@index([gatewayId])
  @@index([nextRetryAt])
  @@index([gateway, status])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPORT
// ─────────────────────────────────────────────────────────────────────────────

model Report {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
