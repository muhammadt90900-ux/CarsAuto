// ─────────────────────────────────────────────────────────────────────────────
// SUBSCRIPTION (per-user plan tracking)
// ─────────────────────────────────────────────────────────────────────────────

// ADR (F1.1 — Unify subscription vocabularies): `Subscription` (this model,
// scoped to a User/buyer) and `DealerSubscription` (scoped to a Dealer) are
// INTENTIONALLY separate models — they represent different product lines
// with different plan catalogs (buyer plans vs dealer plans) and are never
// meant to be merged into one table. What changed here is only that `plan`
// and `status` are now backed by real Prisma enums (UserSubscriptionPlan /
// UserSubscriptionStatus) instead of unconstrained strings, so typos can no
// longer be written to the database. These enums intentionally do NOT share
// values 1:1 with DealerSubscription's SubscriptionPlan/SubscriptionStatus —
// e.g. a buyer's ENTERPRISE plan and a dealer's ENTERPRISE plan are
// unrelated concepts that happen to share a label. Do not assume a plan or
// status value read from one model is comparable to a value from the other.
model Subscription {
  id                     String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId                 String    @unique @db.Uuid
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan                   UserSubscriptionPlan   @default(BASIC)
  status                 UserSubscriptionStatus @default(INACTIVE)

  gatewaySubscriptionId  String?   @unique @db.VarChar(255)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  cancelledAt            DateTime?
  metadata               Json?

  // F1.3: optimistic locking — same rationale as Payment.version. Stripe
  // subscription webhooks (customer.subscription.updated/.deleted,
  // invoice.payment_failed) and our own upsertSubscription() calls from
  // payment-completion paths can race on the same row.
  version                Int       @default(0)

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

// ── Feature 3: Accessory & Service spec model ────────────────────────────────
model ListingAccessorySpec {
  id        String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  listingId String  @unique @db.Uuid
