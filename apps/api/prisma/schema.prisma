  // ── Accessory fields ──────────────────────────────────────────────────────
  brand      String?  @db.VarChar(100)
  model      String?  @db.VarChar(100)
  condition  String?  @db.VarChar(30)   // "NEW" | "USED"
  material   String?  @db.VarChar(100)
  color      String?  @db.VarChar(50)
  weight     Decimal? @db.Decimal(8, 2)
  dimensions String?  @db.VarChar(100)  // "30x20x15 cm"

  // ── Service fields ────────────────────────────────────────────────────────
  serviceType    String?  @db.VarChar(100)  // repair | maintenance | inspection | towing | other
  duration       Int?                        // estimated minutes
  mobile         Boolean  @default(false)    // true = comes to customer
  warranty       Int?                        // warranty in days
  certifications String[] @default([])       // ["ISO", "manufacturer_certified"]
  availableDays  String[] @default([])       // ["mon","tue","wed","thu","fri"]

  // ── Shared ────────────────────────────────────────────────────────────────
  compatibleBrands String[] @default([])
