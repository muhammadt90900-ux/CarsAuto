// ── REPLACE existing model Payment ──────────────────────────────────────────

model Payment {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  user           User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  plan           String    @db.VarChar(50)
  amount         Decimal   @db.Decimal(12, 2)
  currency       String    @db.Char(3)
  status         String    @db.VarChar(30)   // pending | completed | failed | refunded | cancelled

  // Gateway fields
  gatewayId      String?   @unique @db.VarChar(255)   // Stripe PaymentIntent ID
  gatewayStatus  String?   @db.VarChar(50)            // Stripe status mirror

  // Recovery / retry
  retryCount     Int       @default(0)
  nextRetryAt    DateTime?
  failureReason  String?   @db.Text

  // Refund tracking
  refundedAt     DateTime?
  refundAmount   Decimal?  @db.Decimal(12, 2)

  metadata       Json?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  transactionLogs TransactionLog[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@index([gatewayId])
  @@index([nextRetryAt])
  @@map("payments")
}

// ── ADD: TransactionLog ──────────────────────────────────────────────────────

model TransactionLog {
  id           String   @id @default(uuid()) @db.Uuid
  paymentId    String   @db.Uuid
  payment      Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  event        String   @db.VarChar(100)  // created | intent_created | webhook_received | confirmed | failed | refund_initiated | refund_confirmed | retry_scheduled
  status       String   @db.VarChar(50)
  amount       Decimal? @db.Decimal(12, 2)
  currency     String?  @db.Char(3)
  gatewayId    String?  @db.VarChar(255)
  gatewayData  Json?
  errorMessage String?  @db.Text

  createdAt    DateTime @default(now())

  @@index([paymentId])
  @@index([event])
  @@index([createdAt(sort: Desc)])
  @@map("transaction_logs")
}

// ── ADD: WebhookEvent (idempotency log) ──────────────────────────────────────

model WebhookEvent {
  id          String   @id @default(uuid()) @db.Uuid
  gatewayId   String   @unique @db.VarChar(255)  // e.g. evt_xxx from Stripe
  type        String   @db.VarChar(100)
  payload     Json
  processedAt DateTime @default(now())
  error       String?  @db.Text

  @@index([gatewayId])
  @@index([processedAt(sort: Desc)])
  @@map("webhook_events")
}

// ── ADD: Subscription ────────────────────────────────────────────────────────

model Subscription {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @db.Uuid
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan                   String    @default("FREE") @db.VarChar(50)
  status                 String    @default("inactive") @db.VarChar(30) // active | inactive | cancelled | past_due | trialing

  gatewaySubscriptionId  String?   @unique @db.VarChar(255)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  cancelledAt            DateTime?
  metadata               Json?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

