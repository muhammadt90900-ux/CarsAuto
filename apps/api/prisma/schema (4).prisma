// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS — platform
// ─────────────────────────────────────────────

enum UserRole {
  USER
  DEALER
  ADMIN
}

enum ListingType {
  CAR
  MOTORCYCLE
  SPARE_PART
}

enum ListingCondition {
  NEW
  USED
  SALVAGE
}

enum ListingStatus {
  ACTIVE
  SOLD
  DRAFT
  EXPIRED
  PENDING
  REJECTED
}

// ─────────────────────────────────────────────
// ENUMS — automotive
// ─────────────────────────────────────────────

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  PLUG_IN_HYBRID
  ELECTRIC
  LPG
  CNG
  HYDROGEN
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  SEMI_AUTOMATIC
  CVT
  DUAL_CLUTCH
}

enum DrivetrainType {
  FWD
  RWD
  AWD
  FOUR_WD
}

enum BodyType {
  SEDAN
  HATCHBACK
  SUV
  CROSSOVER
  COUPE
  CONVERTIBLE
  WAGON
  PICKUP_TRUCK
  VAN
  MINIVAN
  BUS
  OTHER
}

// ─────────────────────────────────────────────
// AUTOMOTIVE REFERENCE TABLES
// ─────────────────────────────────────────────

model CarBrand {
  id          String    @id @default(uuid())
  slug        String    @unique
  nameEn      String
  nameAr      String
  nameKu      String
  nameZh      String
  logoUrl     String?
  countryCode String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  models              CarModel[]
  listingSpecs        ListingVehicleSpec[]
  partCompatibilities PartCompatibility[]

  @@index([slug])
  @@index([countryCode])
}

model CarModel {
  id        String    @id @default(uuid())
  brandId   String
  brand     CarBrand  @relation(fields: [brandId], references: [id])
  slug      String
  nameEn    String
  nameAr    String
  nameKu    String
  nameZh    String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  generations         CarModelGeneration[]
  listingSpecs        ListingVehicleSpec[]
  partCompatibilities PartCompatibility[]

  @@unique([brandId, slug])
  @@index([brandId])
}

model CarModelGeneration {
  id        String    @id @default(uuid())
  modelId   String
  model     CarModel  @relation(fields: [modelId], references: [id])
  name      String?
  yearFrom  Int
  yearTo    Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  trims CarTrim[]

  @@index([modelId])
  @@index([yearFrom, yearTo])
}

model CarTrim {
  id           String             @id @default(uuid())
  generationId String
  generation   CarModelGeneration @relation(fields: [generationId], references: [id])
  name         String
  bodyType     BodyType
  fuelType     FuelType
  transmission TransmissionType
  drivetrain   DrivetrainType
  engineCC     Int?
  engineLabel  String?
  powerKw      Int?
  doors        Int?
  seats        Int?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  listingSpecs ListingVehicleSpec[]

  @@index([generationId])
  @@index([bodyType])
  @@index([fuelType])
  @@index([drivetrain])
}

// ─────────────────────────────────────────────
// LISTING VEHICLE SPECIFICATION
// ─────────────────────────────────────────────

model ListingVehicleSpec {
  id        String   @id @default(uuid())
  listingId String   @unique
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  trimId   String?
  trim     CarTrim?  @relation(fields: [trimId], references: [id])

  brandId  String?
  brand    CarBrand? @relation(fields: [brandId], references: [id])
  modelId  String?
  model    CarModel? @relation(fields: [modelId], references: [id])

  year         Int?
  bodyType     BodyType?
  fuelType     FuelType?
  transmission TransmissionType?
  drivetrain   DrivetrainType?
  engineCC     Int?
  engineLabel  String?
  powerKw      Int?
  doors        Int?
  seats        Int?
  condition    ListingCondition?
  mileageKm    Int?
  color        String?
  vin          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([modelId])
  @@index([trimId])
  @@index([year])
  @@index([fuelType])
  @@index([bodyType])
  @@index([drivetrain])
  @@index([mileageKm])
  @@index([color])
}

// ─────────────────────────────────────────────
// SPARE PARTS COMPATIBILITY
// ─────────────────────────────────────────────

model PartCompatibility {
  id        String    @id @default(uuid())
  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  brandId   String?
  brand     CarBrand? @relation(fields: [brandId], references: [id])
  modelId   String?
  model     CarModel? @relation(fields: [modelId], references: [id])
  yearFrom  Int?
  yearTo    Int?
  notes     String?

  @@index([listingId])
  @@index([brandId])
  @@index([modelId])
}

// ─────────────────────────────────────────────
// LISTING
// ─────────────────────────────────────────────

model Listing {
  id            String        @id @default(uuid())
  type          ListingType
  status        ListingStatus @default(ACTIVE)
  userId        String
  user          User          @relation(fields: [userId], references: [id])

  titleKu       String
  titleAr       String
  titleEn       String
  titleZh       String
  descriptionKu String?
  descriptionAr String?
  descriptionEn String?
  descriptionZh String?

  price      Float
  currency   String  @default("USD")
  negotiable Boolean @default(false)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  partNumber String?

  views    Int     @default(0)
  featured     Boolean   @default(false)
  featuredUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicleSpec        ListingVehicleSpec?
  partCompatibility  PartCompatibility[]
  images             Image[]
  chats              Chat[]
  favorites          Favorite[]

  @@index([status])
  @@index([type, status])
  @@index([userId])
  @@index([locationId])
  @@index([price])
  @@index([featured, createdAt])
}

// ─────────────────────────────────────────────
// SUPPORTING MODELS
// ─────────────────────────────────────────────

model Image {
  id        String  @id @default(uuid())
  url       String
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  isCover   Boolean @default(false)
  order     Int     @default(0)

  @@index([listingId])
}

model Category {
  id       String     @id @default(uuid())
  parentId String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  nameKu   String
  nameAr   String
  nameEn   String
  nameZh   String
  icon     String?
  slug     String     @unique
  listings Listing[]
}

model Location {
  id          String    @id @default(uuid())
  country     String
  governorate String?
  city        String
  nameKu      String
  nameAr      String
  nameEn      String
  nameZh      String
  lat         Float
  lng         Float
  listings    Listing[]
  dealers     Dealer[]

  @@index([country])
  @@index([city])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String?
  password  String?
  name      String
  avatar    String?
  role      UserRole @default(USER)
  verified  Boolean  @default(false)
  locale    String   @default("ku")
  googleId  String?
  appleId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Security fields ──────────────────────────────────────────────────────
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  passwordChangedAt   DateTime?
  banned              Boolean   @default(false)

  listings        Listing[]
  chatsAsBuyer    Chat[]         @relation("BuyerChats")
  chatsAsSeller   Chat[]         @relation("SellerChats")
  messages        Message[]
  notifications   Notification[]
  reviewsGiven    Review[]       @relation("Reviewer")
  reviewsReceived Review[]       @relation("Reviewee")
  payments        Payment[]
  reports         Report[]
  refreshTokens   RefreshToken[]
  dealer          Dealer?
  dealerReviews       DealerReview[]       @relation("DealerReviewer")
  messageReadReceipts MessageReadReceipt[]
  dealerContacts      DealerContactRequest[] @relation("DealerContacts")
  favorites           Favorite[]
  savedSearches       SavedSearch[]
  pushSubscriptions   PushSubscription[]
  notificationPreference NotificationPreference?
}

// ── Refresh token store ─────────────────────────────────────────────────────
// Raw tokens are NEVER stored — only their SHA-256 hash.
model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique  // SHA-256(rawToken)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Chat {
  id        String    @id @default(uuid())
  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User      @relation("BuyerChats", fields: [buyerId], references: [id])
  sellerId  String
  seller    User      @relation("SellerChats", fields: [sellerId], references: [id])
  status    String    @default("active")
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id        String    @id @default(uuid())
  chatId    String
  chat      Chat      @relation(fields: [chatId], references: [id])
  senderId  String
  sender    User      @relation(fields: [senderId], references: [id])
  content   String
  type      String    @default("text")
  mediaUrl  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  readReceipts MessageReadReceipt[]

  @@index([chatId])
  @@index([senderId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Review {
  id         String   @id @default(uuid())
  reviewerId String
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User     @relation("Reviewee", fields: [revieweeId], references: [id])
  rating     Int
  comment    String
  createdAt  DateTime @default(now())

  @@index([revieweeId])
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  plan      String
  amount    Float
  currency  String
  status    String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id])
  targetType String
  targetId   String
  reason     String
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([reporterId])
  @@index([targetType, targetId])
}

// ── Dealer & Showroom System ────────────────────────────────────────────────

enum DealerTier {
  BASIC       // free, limited listings
  STANDARD    // paid, enhanced visibility
  GOLD        // top-rated badge, priority placement
  PLATINUM    // maximum features, dedicated support
}

enum DealerStatus {
  PENDING     // submitted, awaiting admin review
  VERIFIED    // approved, badge shown
  SUSPENDED   // temporarily disabled
  REJECTED    // application denied
}

enum SubscriptionPlan {
  FREE
  STARTER     // 20 active listings
  BUSINESS    // 100 active listings + analytics
  ENTERPRISE  // unlimited + API access + white-label
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// ─── DEALER PROFILE ──────────────────────────────────────────────────────────

model Dealer {
  id          String       @id @default(uuid())
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  slug        String       @unique          // e.g. "kurdistan-motors"
  nameEn      String
  nameAr      String
  nameKu      String
  taglineEn   String?
  taglineAr   String?
  taglineKu   String?
  descriptionEn String?
  descriptionAr String?
  descriptionKu String?

  // Branding
  logoUrl     String?
  coverUrl    String?
  brandColors Json?                         // { primary: "#c9a84c", accent: "#fff" }

  // Status & tier
  status      DealerStatus  @default(PENDING)
  tier        DealerTier    @default(BASIC)
  verifiedAt  DateTime?
  verifiedBy  String?       // admin user id

  // Contact
  phone       String?
  whatsapp    String?       // full intl number e.g. +9647xxxxxxxx
  email       String?
  website     String?
  instagram   String?
  facebook    String?
  telegram    String?

  // Location
  locationId  String?
  location    Location?     @relation(fields: [locationId], references: [id])
  address     String?
  lat         Float?
  lng         Float?

  // Opening hours (JSON: { mon: "09:00-18:00", ... })
  openingHours Json?

  // Aggregated stats (denormalised for fast reads)
  totalListings   Int     @default(0)
  activeListings  Int     @default(0)
  totalReviews    Int     @default(0)
  averageRating   Float   @default(0)
  totalViews      Int     @default(0)
  responseRate    Float   @default(0)   // 0-100 %
  responseTimeMin Int?                  // median minutes to reply

  // Specialties (array of strings)
  specialties     String[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  showroomImages  ShowroomImage[]
  reviews         DealerReview[]
  analytics       DealerAnalytic[]
  subscription    DealerSubscription?
  contactRequests DealerContactRequest[]
  badges          DealerBadge[]

  @@index([slug])
  @@index([status, tier])
  @@index([locationId])
  @@index([averageRating])
}

// ─── SHOWROOM IMAGES ─────────────────────────────────────────────────────────

model ShowroomImage {
  id        String  @id @default(uuid())
  dealerId  String
  dealer    Dealer  @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  order     Int     @default(0)
  isCover   Boolean @default(false)

  @@index([dealerId])
}

// ─── DEALER REVIEWS ──────────────────────────────────────────────────────────

model DealerReview {
  id          String   @id @default(uuid())
  dealerId    String
  dealer      Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewer    User     @relation("DealerReviewer", fields: [reviewerId], references: [id])

  rating      Int      // 1-5
  title       String?
  body        String
  // Sub-ratings
  ratingService   Int?  // 1-5
  ratingPrice     Int?
  ratingQuality   Int?

  helpful     Int     @default(0)
  verified    Boolean @default(false)  // buyer verified via chat/payment
  flagged     Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dealerId, reviewerId])
  @@index([dealerId, rating])
  @@index([reviewerId])
}

// ─── DEALER BADGES ───────────────────────────────────────────────────────────

model DealerBadge {
  id          String   @id @default(uuid())
  dealerId    String
  dealer      Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  code        String   // e.g. "TOP_RATED", "FAST_RESPONDER", "TRUSTED_SELLER"
  label       String
  icon        String?
  awardedAt   DateTime @default(now())
  expiresAt   DateTime?

  @@index([dealerId])
  @@index([code])
}

// ─── DEALER ANALYTICS ────────────────────────────────────────────────────────

model DealerAnalytic {
  id          String   @id @default(uuid())
  dealerId    String
  dealer      Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date         // day granularity

  profileViews    Int  @default(0)
  listingViews    Int  @default(0)
  contactClicks   Int  @default(0)
  whatsappClicks  Int  @default(0)
  phoneClicks     Int  @default(0)
  searchImpressions Int @default(0)
  newLeads        Int  @default(0)
  newReviews      Int  @default(0)

  @@unique([dealerId, date])
  @@index([dealerId, date])
}

// ─── DEALER SUBSCRIPTION ─────────────────────────────────────────────────────

model DealerSubscription {
  id          String             @id @default(uuid())
  dealerId    String             @unique
  dealer      Dealer             @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  plan        SubscriptionPlan   @default(FREE)
  status      SubscriptionStatus @default(ACTIVE)

  // Billing
  amount      Float?
  currency    String             @default("USD")
  interval    String             @default("month")  // "month" | "year"
  trialEndsAt DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?

  // Limits (derived from plan, stored for quick checks)
  maxListings     Int  @default(5)
  analyticsEnabled Boolean @default(false)
  featuredSlots   Int  @default(0)
  prioritySupport Boolean @default(false)

  // Gateway reference
  gatewayCustomerId    String?
  gatewaySubscriptionId String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

// ─── CONTACT REQUESTS ────────────────────────────────────────────────────────

model DealerContactRequest {
  id          String   @id @default(uuid())
  dealerId    String
  dealer      Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  senderId    String?
  sender      User?    @relation("DealerContacts", fields: [senderId], references: [id])

  name        String
  phone       String?
  email       String?
  message     String
  channel     String   @default("form")  // "form" | "whatsapp" | "phone"
  listingId   String?  // optional — enquiry about specific car
  status      String   @default("new")   // "new" | "read" | "replied"
  readAt      DateTime?

  createdAt   DateTime @default(now())

  @@index([dealerId, status])
  @@index([senderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ADD TO User model:
//
//   dealer             Dealer?
//   dealerReviews      DealerReview[]  @relation("DealerReviewer")
//   dealerContacts     DealerContactRequest[] @relation("DealerContacts")
//
// ADD TO Location model:
//
//   dealers            Dealer[]
// ─────────────────────────────────────────────────────────────────────────────

// ── Admin utility models ──────────────────────────────────────────────────────

model Ad {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String?
  linkUrl     String?
  placement   String   @default("home") // home | listing | sidebar
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ads")
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string | number | boolean | json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Translation {
  id        String   @id @default(uuid())
  locale    String   // en | ku | ar | zh
  namespace String   // common | listing | auth …
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locale, namespace, key])
  @@index([locale, namespace])
  @@map("translations")
}

// ── Chat read receipts ────────────────────────────────────────────────────────

model MessageReadReceipt {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_read_receipts")
}

// ── Missing models required by services ─────────────────────────────────────

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model SavedSearch {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  filters   Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PushSubscription {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint     String   @unique
  subscription Json
  createdAt    DateTime @default(now())

  @@index([userId])
}

model NotificationPreference {
  id                 String  @id @default(uuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled       Boolean @default(true)
  pushEnabled        Boolean @default(true)
  savedSearchAlerts  Boolean @default(true)
  favoriteAlerts     Boolean @default(true)
}
