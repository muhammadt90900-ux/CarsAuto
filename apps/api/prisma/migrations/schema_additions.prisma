// ─── Full updated model for reference ────────────────────────────────────────

model Message {
  id        String    @id @default(uuid()) @db.Uuid
  chatId    String    @db.Uuid
  chat      Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String    @db.Uuid
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Restrict)
  content   String    @db.Text
  type      String    @default("text") @db.VarChar(20)

  // ── Voice note fields (Feature 6) ──────────────────────────────────────────
  messageType   String   @default("text") @db.VarChar(20)   // text | image | voice | system
  audioUrl      String?  @db.VarChar(500)
  audioDuration Int?     // seconds

  mediaUrl  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  readReceipts MessageReadReceipt[]

  @@index([chatId, createdAt(sort: Desc)])
  @@index([senderId])
  @@index([messageType, chatId])
  @@map("messages")
}
