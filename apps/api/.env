# Database
DATABASE_URL=postgresql://carsauto:carsauto123@localhost:5432/autobazaar

# Redis
REDIS_URL=redis://:redis123@localhost:6379

# JWT — must be different values, min 32 chars
JWT_SECRET=carsauto_jwt_secret_key_supersecure_2024_abcdef
JWT_REFRESH_SECRET=carsauto_refresh_secret_key_different_2024_xyz
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email (optional for dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=noreply@carsauto.dev

# Cloudinary (optional for dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payments (optional for dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI (optional for dev)
OPENAI_API_KEY=

# Push notifications (optional for dev)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@carsauto.dev

# Monitoring
LOG_LEVEL=log
SLOW_QUERY_THRESHOLD_MS=500
