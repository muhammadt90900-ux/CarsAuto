# ──────────────────────────────────────────────
# apps/api/.env  —  NestJS / API server
# Copy this file to apps/api/.env and fill in real values.
# DO NOT commit secrets to version control.
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Local dev:  postgresql://user:password@localhost:5432/autobazaar
# Docker:     postgresql://user:password@postgres:5432/autobazaar
# Railway/Render: use the DATABASE_URL provided by the platform
DATABASE_URL="postgresql://user:password@localhost:5432/autobazaar"

# ── Redis ─────────────────────────────────────
# Local dev:  redis://localhost:6379
# Docker:     redis://redis:6379
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-strong-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
FRONTEND_URL="http://localhost:3000"
# Production example: FRONTEND_URL="https://yourdomain.com,https://www.yourdomain.com"

# ── Email (optional) ──────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-smtp-password
# MAIL_FROM=noreply@example.com

# ── Cloudinary (optional) ─────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Postgres (used by docker-compose only) ────
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=autobazaar
DB_PORT=5432
REDIS_PORT=6379
