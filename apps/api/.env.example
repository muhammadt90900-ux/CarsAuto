# ──────────────────────────────────────────────────────────────────────────────
# apps/api/.env.example  —  NestJS / API server
#
# HOW TO USE:
#   cp apps/api/.env.example apps/api/.env
#   Then fill in every CHANGE_ME value with real credentials.
#
# NEVER commit apps/api/.env  (it is listed in .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=log
SLOW_QUERY_THRESHOLD_MS=500

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:  postgresql://user:password@localhost:5432/autobazaar
# Docker:     postgresql://user:password@postgres:5432/autobazaar
# Railway / Render: use the DATABASE_URL provided by the platform
DATABASE_URL="postgresql://CHANGE_ME_user:CHANGE_ME_password@localhost:5432/autobazaar"

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev (no auth):  redis://localhost:6379
# Docker with password: redis://:CHANGE_ME_password@redis:6379
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_char_random_hex_secret
JWT_REFRESH_SECRET=CHANGE_ME_different_min_32_char_random_hex_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Production example: FRONTEND_URL=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=http://localhost:3000

# ── Postgres (used by docker-compose only) ────────────────────────────────────
POSTGRES_USER=CHANGE_ME_user
POSTGRES_PASSWORD=CHANGE_ME_password
POSTGRES_DB=autobazaar
DB_PORT=5432
REDIS_PORT=6379

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Works with SendGrid (SMTP_USER=apikey), Mailgun, AWS SES, etc.
# Leave blank to disable email — app will log a warning and continue.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com

# ── App base URL (used to build email verification links) ─────────────────────
# Must match the public frontend URL so verification links work.
APP_URL=https://carsauto.app

# ── Gmail (alternative to SMTP, for development only) ─────────────────────────
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
# Leave blank to disable image upload feature.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Local file uploads ────────────────────────────────────────────────────────
# Directory where uploaded images are stored on disk.
# For production, point this at a persistent volume or swap the UploadService
# persistFile() method for an S3/Cloudinary adapter.
UPLOAD_DIR=/tmp/uploads
# Public base URL served by the static-assets middleware in main.ts
UPLOAD_BASE_URL=http://localhost:4000/uploads

# ── OpenAI (FEATURE 2: Semantic Search · Price Intelligence · Moderation · Translation) ──
# Leave blank or set OPENAI_ENABLED=false to disable all AI features.
# Sign up at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_ENABLED=true
OPENAI_MODEL_EMBED=text-embedding-3-small
OPENAI_MODEL_CHAT=gpt-4o-mini

# ── Stripe (payments) ─────────────────────────────────────────────────────────
# Use sk_test_... keys for development.
# Leave blank to disable payment features.
STRIPE_SECRET_KEY=

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=60


# ── Seed data (development only) ──────────────────────────────────────────────
# Password used for all seeded demo users. Only needed when running:
#   pnpm --filter api prisma:seed
# Never set this in production — seed script must not run in prod.
SEED_USER_PASSWORD=CHANGE_ME_dev_seed_password
