# ──────────────────────────────────────────────────────────────────────────────
# apps/api/.env.example  —  NestJS / API server
#
# HOW TO USE:
#   cp apps/api/.env.example apps/api/.env
#   Then fill in every CHANGE_ME value with real credentials.
#
# NEVER commit apps/api/.env  (it is listed in .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── API documentation (Swagger/OpenAPI) ───────────────────────────────────────
# Set to "true" to expose interactive API docs at /api/docs. Has NO effect
# when NODE_ENV=production — docs are never served in production regardless
# of this flag (see main.ts for why).
SWAGGER_ENABLED=false
PORT=4000
LOG_LEVEL=log
SLOW_QUERY_THRESHOLD_MS=500

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:  postgresql://user:password@localhost:5432/carsauto
# Docker:     postgresql://user:password@pgbouncer:6432/carsauto  (routed
#             through the pgbouncer service in docker-compose.yml — see its
#             header comment. Do NOT point this at postgres:5432 directly
#             once pgbouncer is running, or its pooling is bypassed.)
# Railway / Render: use the DATABASE_URL provided by the platform (no
#             PgBouncer in front of it there unless you add one as its own
#             service/managed pooler add-on)
DATABASE_URL="postgresql://CHANGE_ME_user:CHANGE_ME_password@localhost:5432/carsauto"

# F-PERF fix: per-PrismaClient pool cap, applied on top of whatever pooling
# PgBouncer already does upstream (see prisma.service.ts's withPoolParams()).
# Each pod creates 2 PrismaClients (write + read), each capped at this limit.
PRISMA_CONNECTION_LIMIT=5
PRISMA_POOL_TIMEOUT=10

# F-PERF fix (Prompt 7): read replicas for db('read') (browse listings,
# search, autocomplete, dealer/admin read-heavy endpoints). Comma-separated
# — see prisma.service.ts's resolveReplicaUrls() header comment for why
# this convention over numbered DATABASE_READ_URL_1/_2/.... Leave empty (or
# set only the single legacy DATABASE_READ_URL below) if you don't have
# replicas yet — db('read') then falls back to DATABASE_URL, same as today.
DATABASE_READ_URLS=
# Legacy single-replica var — still honored if DATABASE_READ_URLS is empty.
DATABASE_READ_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev (no auth):  redis://localhost:6379
# Docker with password: redis://:CHANGE_ME_password@redis:6379
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=

# F-SEC fix (Prompt 6): security-critical state (rate limits, OTP counters,
# token blocklist, WS presence — see critical-state.service.ts) lives on a
# SEPARATE Redis connection from REDIS_URL above, so hot-cache eviction
# (allkeys-lru) can never touch it (this one is noeviction).
# Leave CRITICAL_REDIS_URL unset to fall back to REDIS_URL + a different
# logical db index (CRITICAL_REDIS_DB, default 1) on the SAME instance —
# fine for constrained/single-Redis-instance environments (e.g. a single
# managed Redis add-on). Set CRITICAL_REDIS_URL to point at a genuinely
# separate instance/service if one is available (docker-compose.yml's
# `redis-critical` service does this for local dev).
CRITICAL_REDIS_URL=
CRITICAL_REDIS_DB=1

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_char_random_hex_secret
JWT_REFRESH_SECRET=CHANGE_ME_different_min_32_char_random_hex_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Production example: FRONTEND_URL=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=http://localhost:3000

# ── Postgres (used by docker-compose only) ────────────────────────────────────
POSTGRES_USER=CHANGE_ME_user
POSTGRES_PASSWORD=CHANGE_ME_password
POSTGRES_DB=carsauto
DB_PORT=5432
REDIS_PORT=6379

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Works with SendGrid (SMTP_USER=apikey), Mailgun, AWS SES, etc.
# Leave blank to disable email — app will log a warning and continue.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com

# ── App base URL (used to build email verification links) ─────────────────────
# Must match the public frontend URL so verification links work.
APP_URL=https://carsauto.app

# ── Gmail (alternative to SMTP, for development only) ─────────────────────────
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
# Required — all image uploads (listings, avatars) are stored on Cloudinary's
# CDN. Leaving these blank disables the image upload feature (uploads will
# fail with a clear error rather than falling back to local disk).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OpenAI (FEATURE 2: Semantic Search · Price Intelligence · Moderation · Translation) ──
# Leave blank or set OPENAI_ENABLED=false to disable all AI features.
# Sign up at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_ENABLED=true
OPENAI_MODEL_EMBED=text-embedding-3-small
OPENAI_MODEL_CHAT=gpt-4o-mini

# ── Stripe (payments) ─────────────────────────────────────────────────────────
# Use sk_test_... keys for development.
# Leave blank to disable payment features.
STRIPE_SECRET_KEY=

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=60


# ── Seed data (development only) ──────────────────────────────────────────────
# Password used for all seeded demo users. Only needed when running:
#   pnpm --filter api prisma:seed
# Never set this in production — seed script must not run in prod.
SEED_USER_PASSWORD=CHANGE_ME_dev_seed_password
