# apps/worker/.env.example
#
# The worker shares its database and Redis instance with apps/api — in a
# real deployment these should be the SAME values as apps/api/.env.

NODE_ENV=development

# ── Shared infrastructure (same values as apps/api/.env) ──────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/carsauto
REDIS_URL=redis://localhost:6379

# ── Translation jobs (apps/worker/src/processors/translation.processor.ts) ────
# Leave blank to disable — translation jobs will no-op gracefully.
OPENAI_API_KEY=
OPENAI_ENABLED=true
OPENAI_MODEL_EMBED=text-embedding-3-small
OPENAI_MODEL_CHAT=gpt-4o-mini

# ── Notification jobs (apps/worker/src/processors/email-notification.processor.ts) ──
# Email (pick ONE: Gmail app password OR generic SMTP)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=noreply@carsauto.app

# Web push (optional — leave blank to disable push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=noreply@carsauto.iq

# Slow-query logging threshold for the shared PrismaService copy (ms)
SLOW_QUERY_THRESHOLD_MS=500
