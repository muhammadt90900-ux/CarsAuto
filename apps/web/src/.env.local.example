# ──────────────────────────────────────────────────────────────────────────────
# apps/web/.env.local.example  —  Next.js frontend
#
# HOW TO USE:
#   cp apps/web/.env.local.example apps/web/.env.local
#   Then fill in values for your environment.
#
# NEVER commit apps/web/.env.local  (it is listed in .gitignore)
# Variables prefixed NEXT_PUBLIC_* are exposed to the browser.
# ──────────────────────────────────────────────────────────────────────────────

# ── API base URL ──────────────────────────────────────────────────────────────
# Local dev:             http://localhost:4000/api
# Docker (web → api):   http://api:4000/api   (server-side fetch inside Docker network)
# Vercel / Render:       https://your-api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ── WebSocket URL ─────────────────────────────────────────────────────────────
# Local dev:   http://localhost:4000
# Production:  wss://your-api.yourdomain.com
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── Internal API URL (SSR / server components only) ───────────────────────────
# When the Next.js container talks to the API container on the same Docker
# network, use the internal hostname so traffic never leaves the private network.
# On Vercel this can stay the same as NEXT_PUBLIC_API_URL.
INTERNAL_API_URL=http://localhost:4000/api

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1

# ── Auth (NextAuth / Auth.js — if used) ───────────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=CHANGE_ME_min_32_char_random_secret

# ── Cloudinary (browser-side uploads) ────────────────────────────────────────
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
