# .env.production.template
# Copy to .env.production, fill in real values.
# NEVER commit .env.production to version control.
# All secrets should be injected via your CI/CD secret store.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=carsauto
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=carsauto
DB_PORT=5432
DATABASE_URL=postgresql://carsauto:CHANGE_ME_strong_db_password@postgres:5432/carsauto

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_PORT=6379
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_char_hex_secret
JWT_REFRESH_SECRET=CHANGE_ME_different_64_char_hex_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
LOG_LEVEL=log
SLOW_QUERY_THRESHOLD_MS=500

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of production origins
FRONTEND_URL=https://yourdomain.com,https://www.yourdomain.com

# ── Next.js ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# ── Email (SMTP — works with SendGrid, Mailgun, SES, etc.) ────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME_smtp_password
MAIL_FROM=noreply@yourdomain.com

# ── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=CHANGE_ME_sk_live_or_sk_test_key
STRIPE_WEBHOOK_SECRET=CHANGE_ME_whsec_from_stript_dashboard

# ── Web Push (VAPID) ───────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_EMAIL=noreply@yourdomain.com

# ── Monitoring ─────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password
GRAFANA_URL=https://monitoring.yourdomain.com
