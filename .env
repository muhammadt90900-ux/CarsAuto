# ══════════════════════════════════════════════════════════════
#  CarsAuto — .env  (لۆکاڵ / development)
#  دووپاتکراوەوە لە .env.example
#  ئەم فایلە COMMIT مەکە بۆ Git!
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=carsauto
POSTGRES_PASSWORD=CarsAuto@2026!
POSTGRES_DB=autobazaar
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=Redis@CarsAuto2026!
REDIS_PORT=6379

# ── API (NestJS) ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=log
SLOW_QUERY_THRESHOLD_MS=500

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=4e75f918f7cfc9f6c6de3f21708f24919cf237154a01fe4c63281cc29a14a4df2bbab3fe9b34e9d5d33d6431bec1673d97a7450aa5213d673b3b375f34182212
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Cookie ────────────────────────────────────────────────────
COOKIE_SAME_SITE=lax

# ── Next.js ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=Admin@Grafana2026!
GRAFANA_USER=admin
GRAFANA_PORT=3001
GRAFANA_URL=http://localhost:3001

# ── Prometheus ────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Backup ────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=7
SLACK_WEBHOOK_URL=

# ── Email (SMTP) — ئەگەر نەتەوێت بیکارهێنیت بەتاڵ بهێڵەوە ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=noreply@carsauto.iq

# ── Cloudinary — بۆ ئەپلۆدکردنی وێنە ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OpenAI — بۆ AI features ────────────────────────────────────
OPENAI_API_KEY=

# ── Stripe — بۆ پارەدان ────────────────────────────────────────
STRIPE_SECRET_KEY=

# ── VAPID — بۆ Push Notifications ─────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
